{
  "name": "machine-learning-study",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": "npm run api:serve",
    "api:serve": "node scripts/python-runner.mjs -m uvicorn app.main:app --app-dir apps/api --reload --port 8001",
    "build": "npm --prefix apps/web run build",
    "lint": "npm --prefix apps/web run lint",
    "test": "npm run test:api",
    "test:api": "node scripts/python-runner.mjs -m pytest apps/api/tests"
  }
}
